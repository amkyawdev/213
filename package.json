{
  "name": "burme-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Premium AI Web Application - Burme AI",
  "scripts": {
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:dev": "cd backend && pip install -r requirements.txt && python main.py",
    "build": "cd frontend && npm install && npm run build",
    "start": "cd frontend && npm run preview"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "three": "^0.162.0",
    "@vueuse/core": "^10.9.0",
    "marked": "^12.0.1",
    "katex": "^0.16.9",
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.19.7",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "concurrently": "^8.2.2"
  }
}